{
  "name": "alethe",
  "version": "1.2.3",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:node": "node --test --experimental-strip-types \"tests/**/*.test.ts\"",
    "tauri": "tauri",
    "app": "tauri dev",
    "smoke:ghostty": "bash scripts/smoke-ghostty.sh",
    "capture:window": "bash scripts/capture-window.sh",
    "test:rust": "cd src-tauri && cargo test --lib",
    "test:ghostty": "cd src-tauri && cargo test --lib -- --ignored --test-threads=1 terminal_runs",
    "test": "vitest run",
    "release": "node scripts/release.mjs",
    "release:publish": "node scripts/release-publish.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.15.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^4.10.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "terser": "^5.48.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^2.1.9"
  }
}
